# Evita erros chatos de peer dependencies (React, Apollo, MUI, etc.)
strict-peer-dependencies=false

# Permite que algumas dependências sejam "expostas" no root quando necessário
public-hoist-pattern[]=*

# Garante lockfile estável para equipes e CI/CD
lockfile=true

# Usa resolução mais consistente entre ambientes
shared-workspace-lockfile=true

# Evita conflitos quando múltiplas versões de uma lib aparecem
auto-install-peers=true

# Desabilita scripts pós-instalação que não são necessários
ignore-scripts=false

# Evita problemas com pacotes que dependem de binários
prefer-online=false

# Garante comportamento determinístico
resolution-mode=highest
